{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11",
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        "cd frontend && npm ci && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
