# Talosly Environment Configuration

# Ethereum RPC
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
# Fallback public RPC (used if ALCHEMY_API_KEY is not set):
# ETHEREUM_RPC_URL=https://cloudflare-eth.com

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database
DATABASE_URL=postgresql://talosly:talosly_secret@localhost:5432/talosly
POSTGRES_PASSWORD=talosly_secret

# Auth
API_KEY_SECRET_SALT=random_32_char_string_here

# Worker
POLL_INTERVAL_SECONDS=15
RISK_ALERT_THRESHOLD=70

# Backend
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=5000

# Admin
ADMIN_SECRET=your_admin_secret_key_here_min_32_chars

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# App
APP_ENV=production
PUBLIC_URL=https://talosly.com

# Email
RESEND_API_KEY=your_resend_api_key_here
